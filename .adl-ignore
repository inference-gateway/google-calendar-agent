# .adl-ignore file
# This file specifies which files should not be overwritten during generation operations.
# Files listed here typically contain implementations that users have completed.
#
# Patterns supported:
# - Exact file names: tools/agent_tool.go
# - Wildcards: *.go
# - Directory patterns: skills/*
# - Directories: build/
# - Comments: lines starting with #

internal/google/google.go
tools/check_conflicts.go
tools/create_calendar_event.go
tools/delete_calendar_event.go
tools/find_available_time.go
tools/get_calendar_event.go
tools/list_calendar_events.go
tools/update_calendar_event.go
skills/schedule-meeting/

# Go dependency lock file
go.sum
